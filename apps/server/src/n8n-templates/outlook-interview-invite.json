{
  "name": "Outlook — Send Calendar Invite for Interview",
  "nodes": [
    {
      "id": "webhook-trigger",
      "name": "MatchPoint Webhook",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "path": "matchpoint-interview-calendar",
        "httpMethod": "POST",
        "authentication": "headerAuth"
      },
      "position": [240, 300]
    },
    {
      "id": "filter-event",
      "name": "Filter: interview.scheduled",
      "type": "n8n-nodes-base.if",
      "parameters": {
        "conditions": {
          "string": [{ "value1": "={{ $json.event }}", "operation": "equals", "value2": "interview.scheduled" }]
        }
      },
      "position": [460, 300]
    },
    {
      "id": "calc-end-time",
      "name": "Compute End Time",
      "type": "n8n-nodes-base.set",
      "parameters": {
        "values": {
          "string": [
            { "name": "startDateTime", "value": "={{ $json.payload.scheduledAt }}" },
            { "name": "endDateTime", "value": "={{ new Date(new Date($json.payload.scheduledAt).getTime() + $json.payload.durationMinutes * 60000).toISOString() }}" },
            { "name": "subject", "value": "={{ 'Interview: ' + $json.payload.positionTitle + ($json.payload.candidateName ? ' — ' + $json.payload.candidateName : '') }}" },
            { "name": "body", "value": "={{ '<p>Interview scheduled via MatchPoint Enterprise</p><ul><li><strong>Position:</strong> ' + $json.payload.positionTitle + '</li><li><strong>Candidate:</strong> ' + ($json.payload.candidateName || 'TBD') + '</li><li><strong>Type:</strong> ' + $json.payload.type + '</li><li><strong>Interviewers:</strong> ' + ($json.payload.interviewers || []).join(', ') + '</li>' + ($json.payload.meetingLink ? '<li><strong>Meeting Link:</strong> <a href=\"' + $json.payload.meetingLink + '\">' + $json.payload.meetingLink + '</a></li>' : '') + '</ul>' }}" }
          ]
        }
      },
      "position": [680, 300]
    },
    {
      "id": "create-event",
      "name": "Create Outlook Calendar Event",
      "type": "n8n-nodes-base.microsoftOutlook",
      "parameters": {
        "operation": "create",
        "resource": "event",
        "subject": "={{ $json.subject }}",
        "start": "={{ $json.startDateTime }}",
        "end": "={{ $json.endDateTime }}",
        "bodyContent": "={{ $json.body }}",
        "bodyContentType": "HTML",
        "isOnlineMeeting": "={{ $json.payload.type === 'Video' }}",
        "additionalFields": {
          "attendees": "={{ ($json.payload.interviewers || []).map(email => ({ emailAddress: { address: email }, type: 'required' })) }}"
        }
      },
      "position": [900, 300]
    }
  ],
  "connections": {
    "MatchPoint Webhook": { "main": [[{ "node": "Filter: interview.scheduled", "type": "main", "index": 0 }]] },
    "Filter: interview.scheduled": { "main": [[{ "node": "Compute End Time", "type": "main", "index": 0 }]] },
    "Compute End Time": { "main": [[{ "node": "Create Outlook Calendar Event", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
